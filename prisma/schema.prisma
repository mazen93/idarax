generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                     String                 @id @default(uuid())
  name                   String
  slug                   String?                @unique
  domain                 String?                @unique
  customDomain           String?                @unique
  type                   TenantType
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  hasDeliveryIntegration Boolean                @default(false)
  planId                 String?
  isActive               Boolean                @default(false)
  status                 String                 @default("PENDING") // PENDING | ACTIVE | SUSPENDED
  isTrial                Boolean                @default(true)
  maxBranches            Int                    @default(1)
  maxUsers               Int                    @default(5)
  maxPos                 Int                    @default(1)
  maxKds                 Int                    @default(0)
  subscriptionExpiresAt  DateTime?
  trialExpiresAt         DateTime?
  country                String?                @default("Saudi Arabia")
  countryCode            String?                @default("SA")
  vatNumber              String?
  attendances          Attendance[]
  branches             Branch[]
  branchSettings         BranchSettings[]
  categories             Category[]
  customers              Customer[]
  customerSegments       CustomerSegment[]
  discounts              Discount[]
  drawerSessions         DrawerSession[]
  invoiceCounters        InvoiceCounter[]
  kitchenStations        KitchenStation[]
  marketingCampaigns     MarketingCampaign[]
  marketingRule          MarketingCampaignRule?
  menus                  Menu[]
  notifications          Notification[]
  orders                 Order[]
  orderFeedbacks         OrderFeedback[]
  printers               Printer[]
  products               Product[]
  promoCodes             PromoCode[]
  promoRedemptions       PromoCodeRedemption[]
  promotions             Promotion[]
  purchaseOrders         PurchaseOrder[]
  receiptCounters        ReceiptCounter[]
  reservations           Reservation[]
  rewardCatalogItems     RewardCatalogItem[]
  roles                  Role[]
  rolePermissions        RolePermission[]
  scheduledReports       ScheduledReport[]
  scheduledShifts        ScheduledShift[]
  serialNumbers          SerialNumber[]
  settings               Settings?
  shifts                 Shift[]
  stockMovements         StockMovement[]
  stockTransfers         StockTransfer[]
  tables                 Table[]
  tableSections          TableSection[]
  plan                   SubscriptionPlan?      @relation(fields: [planId], references: [id])
  users                  User[]
  userPermissions        UserPermission[]
  vendors                Vendor[]
  vendorProducts         VendorProduct[]
  waitingEntries         WaitingEntry[]
  warehouses             Warehouse[]
  upgradeRequests        UpgradeRequest[]
  stockAudits            StockAudit[]
  zatcaConfig            ZatcaConfig?
  posDevices             PosDevice[]
}

model Branch {
  id                   String           @id @default(uuid())
  name                 String
  address              String?
  phone                String?
  isActive             Boolean          @default(true)
  tenantId             String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  /// Hour (0-23) at which a new business day begins. Default 0 = midnight.
  /// Set to e.g. 3 for a restaurant that closes at 3 AM so that orders
  /// between midnight and 03:00 still belong to the previous calendar day.
  businessDayStartHour Int              @default(0)
  nameAr               String?
  tenant               Tenant           @relation(fields: [tenantId], references: [id])
  productSettings      BranchProduct[]
  settings             BranchSettings?
  drawerSessions       DrawerSession[]
  kitchenStations      KitchenStation[]
  menus                Menu[]
  orders               Order[]
  printers             Printer[]
  purchaseOrders       PurchaseOrder[]
  attendances          Attendance[]
  receiptCounters      ReceiptCounter[]
  reservations         Reservation[]
  scheduledShifts      ScheduledShift[]
  shifts               Shift[]
  tables               Table[]
  tableSections        TableSection[]
  users                User[]
  waitingEntries       WaitingEntry[]
  warehouses           Warehouse[]
  posDevices           PosDevice[]

  @@unique([name, tenantId])
}

model Settings {
  id                          String   @id @default(uuid())
  tenantId                    String   @unique
  currency                    String   @default("USD")
  timezone                    String   @default("UTC")
  country                     String?  @default("Saudi Arabia")
  countryCode                 String?  @default("SA")
  logoUrl                     String?
  receiptFooter               String?
  receiptHeader               String?
  serviceFee                  Decimal? @default(0)
  taxRate                     Decimal? @default(0)
  receiptFontSize             Int      @default(12)
  receiptQrCodeUrl            String?
  receiptShowCustomer         Boolean  @default(true)
  receiptShowLogo             Boolean  @default(true)
  receiptShowOrderNumber      Boolean  @default(true)
  receiptShowTable            Boolean  @default(true)
  aboutUsText                 String?
  bannerImageUrl              String?
  contactEmail                String?
  contactPhone                String?
  facebookUrl                 String?
  instagramUrl                String?
  receiptLanguage             String   @default("en")
  receiptShowBarcode          Boolean  @default(true)
  receiptShowDiscount         Boolean  @default(true)
  receiptShowItemsDescription Boolean  @default(true)
  receiptShowItemsPrice       Boolean  @default(true)
  receiptShowItemsQty         Boolean  @default(true)
  receiptShowOperator         Boolean  @default(true)
  receiptShowOrderType        Boolean  @default(true)
  receiptShowPaymentMethod    Boolean  @default(true)
  receiptShowServiceCharge    Boolean  @default(true)
  receiptShowSubtotal         Boolean  @default(true)
  receiptShowTax              Boolean  @default(true)
  receiptShowTimestamp        Boolean  @default(true)
  receiptShowTotal            Boolean  @default(true)
  twitterUrl                  String?
  drovoApiKey                 String?
  drovoTenantId               String?
  brandColor                  String   @default("#10b981")
  secondaryColor              String   @default("#1f2937")
  loyaltyRatioEarning         Decimal  @default(1.0)
  loyaltyRatioRedemption      Decimal  @default(0.01)
  
  /// Pre-order: allow customers to schedule orders for a future time
  preOrderEnabled             Boolean  @default(false)
  /// How many days ahead a customer can schedule (default 7)
  preOrderMaxDaysAhead        Int      @default(7)
  /// Minutes before scheduledAt the kitchen is notified (default 30)
  preOrderLeadMinutes         Int      @default(30)
  
  // ZATCA (Saudi Arabia) Fiscal Compliance
  zatcaVatNumber              String?
  zatcaSellerNameAr           String?
  zatcaSellerNameEn           String?
  zatcaPhase                  Int?     @default(1)
  zatcaEgsUuid                String?
  zatcaEgsSerial              String?
  zatcaIsOnboarded            Boolean  @default(false)
  
  /// Enforcement settings
  requireOpenShift            Boolean  @default(false)
  requireOpenDrawer           Boolean  @default(false)

  tenant                      Tenant   @relation(fields: [tenantId], references: [id])
}

model BranchSettings {
  id                          String   @id @default(uuid())
  branchId                    String   @unique
  tenantId                    String
  isActive                    Boolean  @default(true)
  taxRate                     Decimal?
  serviceFee                  Decimal?
  receiptHeader               String?
  receiptFooter               String?
  receiptLanguage             String?
  receiptShowCustomer         Boolean?
  receiptShowLogo             Boolean?
  receiptShowOrderNumber      Boolean?
  receiptShowTable            Boolean?
  receiptShowTimestamp        Boolean?
  receiptShowOrderType        Boolean?
  receiptShowOperator         Boolean?
  receiptShowItemsDescription Boolean?
  receiptShowItemsQty         Boolean?
  receiptShowItemsPrice       Boolean?
  receiptShowSubtotal         Boolean?
  receiptShowTax              Boolean?
  receiptShowServiceCharge    Boolean?
  receiptShowDiscount         Boolean?
  receiptShowTotal            Boolean?
  receiptShowPaymentMethod    Boolean?
  receiptShowBarcode          Boolean?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  cdsEnabled                  Boolean? @default(false)
  cdsIdleImages               String[]
  cdsShowPromotions           Boolean? @default(true)
  /// Pre-order: allow customers to schedule orders for a future time
  preOrderEnabled             Boolean? @default(false)
  /// How many days ahead a customer can schedule (default 7)
  preOrderMaxDaysAhead        Int?     @default(7)
  /// Minutes before scheduledAt the kitchen is notified (default 30)
  preOrderLeadMinutes         Int?     @default(30)
  
  /// Enforcement settings (overrides global if not null)
  requireOpenShift            Boolean?
  requireOpenDrawer           Boolean?
  branch                      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenant                      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  name            String
  role            UserRole         @default(STAFF)
  tenantId        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  branchId        String?
  pinCode         String?
  roleId          String?
  isActive        Boolean          @default(true)
  hourlyRate      Decimal?
  fixedSalary     Decimal?
  attendances     Attendance[]
  drawerSessions  DrawerSession[]
  orders          Order[]
  scheduledShifts ScheduledShift[]
  shifts          Shift[]
  branch          Branch?          @relation(fields: [branchId], references: [id])
  customRole      Role?            @relation(fields: [roleId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  permissions     UserPermission[]
  sessions        UserSession[]
  kitchenStations KitchenStation[] @relation("KitchenStationToUser")

  @@unique([pinCode, tenantId])
  @@index([pinCode, tenantId])
}

model UserPermission {
  id       String @id @default(uuid())
  userId   String
  action   String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action])
  @@index([userId])
  @@index([tenantId])
}

model Role {
  id          String           @id @default(uuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       User[]

  @@unique([name, tenantId])
}

model RolePermission {
  id       String @id @default(uuid())
  roleId   String
  action   String
  tenantId String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([roleId, action])
  @@index([roleId])
  @@index([tenantId])
}

model Category {
  id               String          @id @default(uuid())
  name             String
  tenantId         String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  description      String?
  descriptionAr    String?
  nameAr           String?
  defaultPrepTime  Int             @default(0)
  defaultStationId String?
  defaultStation   KitchenStation? @relation("CategoryDefaultStation", fields: [defaultStationId], references: [id])
  imageUrl         String?
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  menus            MenuCategory[]
  products         Product[]

  @@unique([name, tenantId])
}

model Menu {
  id         String         @id @default(uuid())
  name       String
  nameAr     String?
  startTime  String
  endTime    String
  daysOfWeek Int[]
  tenantId   String
  branchId   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  branch     Branch?        @relation(fields: [branchId], references: [id])
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  categories MenuCategory[]

  @@index([tenantId, branchId])
}

model MenuCategory {
  menuId     String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  menu       Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([menuId, categoryId])
}

model Product {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  price              Decimal
  sku                String?
  barcode            String?
  tenantId           String
  categoryId         String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  costPrice          Decimal             @default(0)
  isSellable         Boolean             @default(true)
  productType        ProductType         @default(STANDARD)
  descriptionAr      String?
  nameAr             String?
  defaultStationId   String?
  prepTime           Int                 @default(0)
  unit               String?             @default("unit")
  branchSettings     BranchProduct[]
  orderItems         OrderItem[]
  category           Category            @relation(fields: [categoryId], references: [id])
  defaultStation     KitchenStation?     @relation("ProductDefaultStation", fields: [defaultStationId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  modifiers          ProductModifier[]
  usedInRecipes      ProductRecipe[]     @relation("RecipeIngredient")
  recipeComponents   ProductRecipe[]     @relation("RecipeParent")
  purchaseOrderItems PurchaseOrderItem[]
  rewardCatalogItems RewardCatalogItem[]
  serialNumbers      SerialNumber[]
  stockLevels        StockLevel[]
  stockMovements     StockMovement[]
  stockTransfers     StockTransfer[]
  stockAuditItems    StockAuditItem[]
  imageUrl           String?
  variants           Variant[]
  vendorProducts     VendorProduct[]

  @@unique([sku, tenantId])
  @@unique([barcode, tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, categoryId])
}

model BranchProduct {
  id               String          @id @default(uuid())
  branchId         String
  productId        String
  isAvailable      Boolean         @default(true)
  priceOverride    Decimal?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  defaultStationId String?
  branch           Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  defaultStation   KitchenStation? @relation("BranchProductDefaultStation", fields: [defaultStationId], references: [id])
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
}

model Variant {
  id         String          @id @default(uuid())
  name       String
  price      Decimal?
  sku        String?
  productId  String
  costPrice  Decimal         @default(0)
  orderItems OrderItem[]
  recipes    ProductRecipe[]
  product    Product         @relation(fields: [productId], references: [id])

  @@unique([sku, productId])
}

model Table {
  id            String        @id @default(uuid())
  capacity      Int
  status        String        @default("AVAILABLE")
  tenantId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  number        Int
  branchId      String?
  isMerged      Boolean       @default(false)
  parentTableId String?
  sectionId     String?
  qrCodeUrl     String?
  orders        Order[]
  reservations  Reservation[]
  branch        Branch?       @relation(fields: [branchId], references: [id])
  section       TableSection? @relation(fields: [sectionId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([number, tenantId, branchId])
}

model TableSection {
  id        String   @id @default(uuid())
  name      String
  tenantId  String
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nameAr    String?
  tables    Table[]
  branch    Branch?  @relation(fields: [branchId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([name, tenantId, branchId])
}

model Order {
  id                String                @id @default(uuid())
  status            OrderStatus           @default(PENDING)
  totalAmount       Decimal
  tenantId          String
  customerId        String?
  tableId           String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  note              String?
  paidAmount        Decimal               @default(0)
  paymentMethod     String                @default("CASH")
  branchId          String?
  guestName         String?
  guestPhone        String?
  deliveryAddress   String?
  discountAmount    Decimal?              @default(0)
  /// Permanent globally-unique invoice number e.g. INV-20250313-0042
  invoiceNumber     String?               @unique
  offerCode         String?
  /// Short daily receipt number (1-999, resets each business day per branch)
  receiptNumber     Int?
  serviceFeeAmount  Decimal?              @default(0)
  taxAmount         Decimal?              @default(0)
  userId            String?
  orderType         OrderType             @default(IN_STORE)
  deliveryFee       Decimal?              @default(0)
  externalOrderId   String?
  externalPlatform  String?
  isSplit           Boolean               @default(false)
  parentOrderId     String?
  source            OrderSource           @default(POS)
  loyaltyCashback   Decimal               @default(0)
  loyaltyPointsUsed Int                   @default(0)
  /// Pre-order: the customer's requested pickup/delivery time
  scheduledAt       DateTime?
  isPreOrder        Boolean               @default(false)
  branch            Branch?               @relation(fields: [branchId], references: [id])
  customer          Customer?             @relation(fields: [customerId], references: [id])
  table             Table?                @relation(fields: [tableId], references: [id])
  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  user              User?                 @relation(fields: [userId], references: [id])
  feedback          OrderFeedback?
  items             OrderItem[]
  payments          Payment[]
  promoRedemptions  PromoCodeRedemption[]
  refunds           Refund[]
  zatcaReport       ZatcaInvoiceReport?

  @@index([tenantId, branchId, receiptNumber])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([invoiceNumber])
  @@index([tenantId, scheduledAt])
}

model OrderItem {
  id            String              @id @default(uuid())
  quantity      Int
  price         Decimal
  status        OrderItemStatus     @default(PENDING)
  orderId       String
  productId     String
  stationId     String?
  note          String?
  courseName    String?
  variantId     String?
  completedAt   DateTime?
  costPrice     Decimal             @default(0)
  fireAt        DateTime?
  startedAt     DateTime?
  isReward      Boolean             @default(false)
  pointsCost    Int                 @default(0)
  order         Order               @relation(fields: [orderId], references: [id])
  product       Product             @relation(fields: [productId], references: [id])
  station       KitchenStation?     @relation(fields: [stationId], references: [id])
  variant       Variant?            @relation(fields: [variantId], references: [id])
  modifiers     OrderItemModifier[]
  refundItems   RefundItem[]
  serialNumbers SerialNumber[]

  @@index([orderId])
  @@index([productId])
  @@index([orderId, productId])
}

// ZATCA (Saudi Arabia) Fiscal Integration
model ZatcaConfig {
  id                   String   @id @default(uuid())
  tenantId             String   @unique
  branchId             String?  @unique
  privateKey           String   @db.Text
  publicKey            String   @db.Text
  certificate          String?  @db.Text
  csr                  String?  @db.Text
  secret               String?
  binaryToken          String?  @db.Text
  pih                  String?  @db.Text // Previous Invoice Hash (mandatory for chaining in Phase 2)
  environment          String   @default("SANDBOX") // SANDBOX or PRODUCTION
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ZatcaInvoiceReport {
  id              String      @id @default(uuid())
  orderId         String      @unique
  status          ZatcaStatus @default(PENDING)
  invoiceHash     String?
  qrCode          String?     @db.Text
  xmlBase64       String?     @db.Text
  responsePayload Json?
  errors          Json?
  reportedAt      DateTime?
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

enum ZatcaStatus {
  PENDING
  REPORTED
  CLEARED
  FAILED
}

model KitchenStation {
  id                       String          @id @default(uuid())
  name                     String
  tenantId                 String
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  branchId                 String?
  nameAr                   String?
  defaultForBranchProducts BranchProduct[] @relation("BranchProductDefaultStation")
  defaultForCategories     Category[]      @relation("CategoryDefaultStation")
  branch                   Branch?         @relation(fields: [branchId], references: [id])
  tenant                   Tenant          @relation(fields: [tenantId], references: [id])
  orderItems               OrderItem[]
  defaultForProducts       Product[]       @relation("ProductDefaultStation")
  assignedStaff            User[]          @relation("KitchenStationToUser")

  @@unique([name, tenantId, branchId])
}

model SerialNumber {
  id          String       @id @default(uuid())
  serial      String
  status      SerialStatus @default(AVAILABLE)
  tenantId    String
  productId   String
  orderItemId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orderItem   OrderItem?   @relation(fields: [orderItemId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([serial, tenantId])
}

model Customer {
  id                 String                @id @default(uuid())
  name               String
  email              String?
  phone              String?               @unique
  points             Int                   @default(0)
  tenantId           String
  createdAt          DateTime              @default(now())
  loyaltyTier        LoyaltyTier           @default(BRONZE)
  totalSpend         Decimal               @default(0)
  birthday           DateTime?
  referralCode       String?               @unique
  referredById       String?
  referredBy         Customer?             @relation("Referrals", fields: [referredById], references: [id])
  referrals          Customer[]            @relation("Referrals")
  tenant             Tenant                @relation(fields: [tenantId], references: [id])
  addresses          CustomerAddress[]
  loyaltyHistory     CustomerLoyalty[]
  marketingCampaigns MarketingCampaign[]
  orders             Order[]
  promoRedemptions   PromoCodeRedemption[]
  reservations       Reservation[]
  waitingEntries     WaitingEntry[]
  segments           CustomerSegment[]     @relation("CustomerToCustomerSegment")

  @@index([tenantId, createdAt])
  @@index([tenantId, phone])
}

model CustomerSegment {
  id          String     @id @default(uuid())
  name        String
  description String?
  color       String?
  tenantId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  customers   Customer[] @relation("CustomerToCustomerSegment")
}

model CustomerLoyalty {
  id          String   @id @default(uuid())
  customerId  String
  points      Int
  type        String
  description String?
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id])
}

model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  label      String   @default("Home")
  address    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lat        Float?
  lng        Float?
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Discount {
  id                   String    @id @default(uuid())
  code                 String    @unique
  description          String?
  type                 String
  value                Decimal
  isActive             Boolean   @default(true)
  tenantId             String
  createdAt            DateTime  @default(now())
  applicableProductIds String[]
  maxDiscountAmount    Decimal?
  minOrderAmount       Decimal?
  validFrom            DateTime?
  validUntil           DateTime?
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
}

model Promotion {
  id                   String        @id @default(uuid())
  name                 String
  description          String?
  type                 PromotionType
  buyQuantity          Int?
  getQuantity          Int?
  discountValue        Decimal?
  maxDiscountAmount    Decimal?
  minOrderAmount       Decimal?
  isActive             Boolean       @default(true)
  validFrom            DateTime?
  validUntil           DateTime?
  applicableProductIds String[]
  tenantId             String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  customerSegment      String?
  freeItemProductId    String?
  happyHourDays        Int[]
  happyHourEnd         String?
  happyHourStart       String?
  isBirthdayBonus      Boolean       @default(false)
  tierThresholds       Json?
  promoCodes           PromoCode[]
  tenant               Tenant        @relation(fields: [tenantId], references: [id])
}

model PromoCode {
  id                   String                @id @default(uuid())
  code                 String                @unique
  promotionId          String
  maxUsages            Int?
  usedCount            Int                   @default(0)
  tenantId             String
  createdAt            DateTime              @default(now())
  firstOrderOnly       Boolean               @default(false)
  isStackable          Boolean               @default(false)
  maxUsagesPerCustomer Int?
  staffOnly            Boolean               @default(false)
  promotion            Promotion             @relation(fields: [promotionId], references: [id])
  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  redemptions          PromoCodeRedemption[]
}

model PromoCodeRedemption {
  id              String    @id @default(uuid())
  promoCodeId     String
  customerId      String
  orderId         String
  discountApplied Decimal
  redeemedAt      DateTime  @default(now())
  tenantId        String
  customer        Customer  @relation(fields: [customerId], references: [id])
  order           Order     @relation(fields: [orderId], references: [id])
  promoCode       PromoCode @relation(fields: [promoCodeId], references: [id])
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
}

model MarketingCampaignRule {
  id                   String   @id @default(uuid())
  tenantId             String   @unique
  name                 String   @default("Win-Back Campaign")
  isActive             Boolean  @default(true)
  inactiveDays         Int      @default(30)
  discountValue        Decimal  @default(15)
  discountType         String   @default("PERCENTAGE_OFF")
  emailSubject         String   @default("We miss you!")
  emailContent         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  birthdayActive       Boolean  @default(false)
  birthdayContent      String?
  birthdayReward       Decimal  @default(10)
  birthdayRewardType   String   @default("PERCENTAGE_OFF")
  birthdaySubject      String   @default("Happy Birthday, {{customer_name}}!")
  referralActive       Boolean  @default(false)
  referralContent      String?
  referralFriendReward Decimal  @default(25)
  referralReward       Decimal  @default(50)
  referralSubject      String   @default("Gift from {{referrer_name}}!")
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  amount    Decimal
  method    String
  status    String
  reference String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model Warehouse {
  id                String          @id @default(uuid())
  name              String
  location          String?
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  branchId          String?
  nameAr            String?
  purchaseOrders    PurchaseOrder[]
  stockLevels       StockLevel[]
  stockMovements    StockMovement[]
  incomingTransfers StockTransfer[] @relation("DestinationWarehouse")
  outgoingTransfers StockTransfer[] @relation("SourceWarehouse")
  branch            Branch?         @relation(fields: [branchId], references: [id])
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  stockAudits       StockAudit[]

  @@unique([name, tenantId, branchId])
}

model StockLevel {
  id           String    @id @default(uuid())
  productId    String
  warehouseId  String
  quantity     Int       @default(0)
  minThreshold Int       @default(5)
  maxThreshold Int?
  updatedAt    DateTime  @updatedAt
  product      Product   @relation(fields: [productId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model StockMovement {
  id          String       @id @default(uuid())
  productId   String
  warehouseId String
  quantity    Int
  type        MovementType
  referenceId String?
  tenantId    String
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id])
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([productId, warehouseId])
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  tenantId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  nameAr         String?
  purchaseOrders PurchaseOrder[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  products       VendorProduct[]
}

model VendorProduct {
  id        String   @id @default(uuid())
  vendorId  String
  productId String
  costPrice Decimal  @default(0)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  vendor    Vendor   @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, productId])
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  number      String              @unique
  vendorId    String
  tenantId    String
  branchId    String?
  warehouseId String?
  status      PurchaseOrderStatus @default(PENDING)
  totalAmount Decimal             @default(0)
  note        String?
  orderedAt   DateTime?
  receivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  vendor      Vendor              @relation(fields: [vendorId], references: [id])
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  branch      Branch?             @relation(fields: [branchId], references: [id])
  warehouse   Warehouse?          @relation(fields: [warehouseId], references: [id])
  items       PurchaseOrderItem[]

  @@index([tenantId, createdAt])
  @@index([vendorId, status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  receivedQty     Int           @default(0)
  costPrice       Decimal
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@unique([purchaseOrderId, productId])
}

model StockTransfer {
  id            String    @id @default(uuid())
  tenantId      String
  sourceId      String
  destinationId String
  productId     String
  quantity      Int
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  destination   Warehouse @relation("DestinationWarehouse", fields: [destinationId], references: [id])
  product       Product   @relation(fields: [productId], references: [id])
  source        Warehouse @relation("SourceWarehouse", fields: [sourceId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
}

model StockAudit {
  id          String           @id @default(uuid())
  tenantId    String
  warehouseId String
  status      String           @default("PENDING") // PENDING, COMPLETED, CANCELLED
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  items       StockAuditItem[]

  @@index([tenantId, createdAt])
}

model StockAuditItem {
  id               String     @id @default(uuid())
  auditId          String
  productId        String
  expectedQuantity Float
  physicalQuantity Float
  variance         Float
  audit            StockAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  product          Product    @relation(fields: [productId], references: [id])

  @@index([auditId])
}

/// Global invoice sequence counter per tenant per business date.
/// Never resets — only the date prefix changes each business day.
model InvoiceCounter {
  id       String @id @default(uuid())
  tenantId String
  /// Business date string YYYYMMDD (adjusted by branch businessDayStartHour)
  date     String
  sequence Int    @default(0)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId, date])
}

/// Per-branch daily receipt counter (1-999, resets each business day).
model ReceiptCounter {
  id       String  @id @default(uuid())
  tenantId String
  branchId String?
  /// Business date string YYYYMMDD (adjusted by branch businessDayStartHour)
  date     String
  sequence Int     @default(0)
  branch   Branch? @relation(fields: [branchId], references: [id])
  tenant   Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, branchId, date])
  @@index([tenantId, branchId, date])
}

model LandingContent {
  id        String   @id @default(uuid())
  section   String   @unique
  title     String
  content   String?
  items     Json?
  theme     String   @default("default")
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique
  price         Decimal  @db.Decimal(10, 2)
  features      String[]
  maxPos        Int      @default(1)
  maxKds        Int      @default(0)
  maxBranches   Int      @default(1)
  maxUsers      Int      @default(5)
  isActive      Boolean  @default(true)
  updatedAt     DateTime @updatedAt
  description   String?
  descriptionAr String?
  featuresAr    String[]
  nameAr        String?
  tenants       Tenant[]
  upgradeRequestsFrom UpgradeRequest[] @relation("FromPlan")
  upgradeRequestsTo   UpgradeRequest[] @relation("ToPlan")
}

model UpgradeRequest {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  fromPlanId  String?
  fromPlan    SubscriptionPlan? @relation("FromPlan", fields: [fromPlanId], references: [id])
  toPlanId    String
  toPlan      SubscriptionPlan  @relation("ToPlan", fields: [toPlanId], references: [id])
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  note        String?
  requestedAt DateTime @default(now())
  processedAt DateTime?
}

model Reservation {
  id         String    @id @default(uuid())
  tenantId   String
  tableId    String?
  customerId String?
  guestName  String
  guestPhone String?
  partySize  Int       @default(1)
  date       DateTime
  note       String?
  status     String    @default("UPCOMING")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  branchId   String?
  branch     Branch?   @relation(fields: [branchId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  table      Table?    @relation(fields: [tableId], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
}

model WaitingEntry {
  id         String    @id @default(uuid())
  tenantId   String
  guestName  String
  guestPhone String?
  partySize  Int       @default(1)
  note       String?
  status     String    @default("WAITING")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  branchId   String?
  customerId String?
  branch     Branch?   @relation(fields: [branchId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
}

model ProductRecipe {
  id           String   @id @default(uuid())
  parentId     String
  ingredientId String
  quantity     Decimal
  unit         String   @default("unit")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  variantId    String?
  ingredient   Product  @relation("RecipeIngredient", fields: [ingredientId], references: [id])
  parent       Product  @relation("RecipeParent", fields: [parentId], references: [id])
  variant      Variant? @relation(fields: [variantId], references: [id])

  @@unique([parentId, ingredientId, variantId])
}

model Printer {
  id        String   @id @default(uuid())
  name      String
  type      String
  interface String
  address   String?
  tenantId  String
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch?  @relation(fields: [branchId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([name, tenantId, branchId])
}

model Refund {
  id            String       @id @default(uuid())
  orderId       String
  amount        Decimal
  reason        String?
  paymentMethod String       @default("CASH")
  createdAt     DateTime     @default(now())
  order         Order        @relation(fields: [orderId], references: [id])
  items         RefundItem[]
}

model RefundItem {
  id          String    @id @default(uuid())
  refundId    String
  orderItemId String
  quantity    Int
  amount      Decimal
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  refund      Refund    @relation(fields: [refundId], references: [id])
}

model Shift {
  id        String       @id @default(uuid())
  userId    String
  tenantId  String
  branchId  String?
  startTime DateTime     @default(now())
  endTime   DateTime?
  status    ShiftStatus  @default(OPEN)
  note      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  branch    Branch?      @relation(fields: [branchId], references: [id])
  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  user      User         @relation(fields: [userId], references: [id])
  breaks    ShiftBreak[]

  @@index([tenantId, startTime])
}

model ShiftBreak {
  id        String    @id @default(uuid())
  shiftId   String
  startTime DateTime  @default(now())
  endTime   DateTime?
  type      BreakType @default(LUNCH)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  shift     Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model DrawerSession {
  id              String         @id @default(uuid())
  userId          String
  tenantId        String
  branchId        String?
  openingBalance  Decimal        @default(0)
  closingBalance  Decimal?
  expectedBalance Decimal?
  status          DrawerStatus   @default(OPEN)
  note            String?
  openedAt        DateTime       @default(now())
  closedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  movements       CashMovement[]
  branch          Branch?        @relation(fields: [branchId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  user            User           @relation(fields: [userId], references: [id])

  @@index([tenantId, openedAt])
}

model CashMovement {
  id          String           @id @default(uuid())
  sessionId   String
  amount      Decimal
  type        CashMovementType
  reason      String?
  referenceId String?
  createdAt   DateTime         @default(now())
  session     DrawerSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model ProductModifier {
  id          String                  @id @default(uuid())
  name        String
  required    Boolean                 @default(false)
  multiSelect Boolean                 @default(false)
  sortOrder   Int                     @default(0)
  productId   String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  nameAr      String?
  product     Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  options     ProductModifierOption[]
}

model ProductModifierOption {
  id                 String              @id @default(uuid())
  name               String
  priceAdjust        Decimal             @default(0)
  sortOrder          Int                 @default(0)
  modifierId         String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  nameAr             String?
  orderItemModifiers OrderItemModifier[]
  modifier           ProductModifier     @relation(fields: [modifierId], references: [id], onDelete: Cascade)
}

model OrderItemModifier {
  id        String                @id @default(uuid())
  price     Decimal
  optionId  String
  itemId    String
  createdAt DateTime              @default(now())
  item      OrderItem             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  option    ProductModifierOption @relation(fields: [optionId], references: [id])
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String?
  userEmail    String?
  action       String
  resourceType String?
  resourceId   String?
  meta         Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model GlobalSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model UserSession {
  id                 String   @id @default(uuid())
  userId             String
  tenantId           String
  jti                String   @unique
  deviceName         String?
  ipAddress          String?
  isActive           Boolean  @default(true)
  lastSeenAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  hashedRefreshToken String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([jti])
}

model ScheduledReport {
  id             String       @id @default(uuid())
  tenantId       String
  type           ReportType
  format         ReportFormat @default(PDF)
  recipientEmail String
  isActive       Boolean      @default(true)
  lastSentAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tenant         Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model ScheduledShift {
  id        String               @id @default(uuid())
  userId    String
  tenantId  String
  branchId  String
  startAt   DateTime
  endAt     DateTime
  status    ScheduledShiftStatus @default(PUBLISHED)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  branch    Branch               @relation(fields: [branchId], references: [id])
  tenant    Tenant               @relation(fields: [tenantId], references: [id])
  user      User                 @relation(fields: [userId], references: [id])

  @@index([userId, startAt])
  @@index([tenantId])
}

model OrderFeedback {
  id        String   @id @default(uuid())
  orderId   String   @unique
  tenantId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  branchId  String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  meta      Json?
  createdAt DateTime         @default(now())
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isRead])
  @@index([tenantId, createdAt])
}

model MarketingCampaign {
  id           String   @id @default(uuid())
  tenantId     String
  customerId   String
  campaignType String
  status       String
  sentAt       DateTime @default(now())
  metadata     Json?
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
}

model RewardCatalogItem {
  id         String   @id @default(uuid())
  tenantId   String
  productId  String
  pointsCost Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId])
}

